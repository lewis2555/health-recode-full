name: Build Android APK with Buildozer
on:
  push:
    branches: [ main, master ]
  workflow_dispatch:
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
    - name: Checkout code
      uses: actions/checkout@v4
    - name: Set up JDK 17
      uses: actions/setup-java@v4
      with:
        java-version: '17'
        distribution: 'temurin'
    - name: Install dependencies
      run: |
        sudo apt-get update
        sudo apt-get install -y git python3-pip python3-venv build-essential                                 libssl-dev libffi-dev                                 libncurses5-dev git wget unzip                                 openjdk-17-jdk-headless
    - name: Install Buildozer
      run: |
        python3 -m pip install --upgrade pip
        python3 -m pip install buildozer cython==0.29.36
    - name: Build APK
      run: |
        buildozer android debug deploy run
      working-directory: ${{ github.workspace }}
    - name: Upload APK
      uses: actions/upload-artifact@v4
      with:
        name: app-apk
        path: |
          **/*.apk
          !**/.git/**
        retention-days: 30
